{
  "name": "gpt-blur",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Floutage visuel des titres de conversations ChatGPT dans la barre latérale",
  "scripts": {
    "prebuild": "node scripts/generate-placeholder-icons.mjs",
    "dev": "node scripts/generate-placeholder-icons.mjs && vite build --watch",
    "build": "tsc --noEmit && vite build",
    "pack": "npm run build && node scripts/zip-dist.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.0.278",
    "@types/node": "^22.10.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0"
  }
}
